p=input("Enter a password")
if len(p)<8 or len(p)>15:
    print("Invalid")
elif not any(ch.isdigit() for ch in p):
    print("Invalid")
elif not any(ch.islower() for ch in p):
    print("Invalid")
elif not any(ch.islower() for ch in p):
    print("Invalid")
elif not any(ch.isupper() for ch in p):
    print("Invalid")
elif not any(ch in "!@#$%^&*" for ch in p):
    print("Invalid")
else:
    print("Valid")
